# ─── Django Settings ─────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── News API  (https://newsapi.org) ─────────────────────────────────────────
# Free tier: 100 requests/day. Leave blank to use yfinance news fallback.
NEWS_API_KEY=

# ─── Alpha Vantage (https://www.alphavantage.co) ─────────────────────────────
# Free tier: 25 requests/day. Used as supplementary financial data source.
ALPHA_VANTAGE_API_KEY=
